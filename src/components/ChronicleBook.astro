---
import "../styles/sections/_experience.scss";

const pages = [
    {
        title: "Prólogo",
        dropCap: "D",
        html: `<p>esarrollador y apasionado de la informática con máster en programación por Rock The Code y experiencia en tecnologías como React, Next.js, Angular, Express, MongoDB y PostgreSQL.</p>
        <p>He trabajado en proyectos destacados, como un sistema de tracking en tiempo real. Actualmente, estudiando Desarrollo de Aplicaciones Multiplataforma (DAM) en Retamar para profundizar en mis conocimientos de programación.</p>`,
    },
    {
        title: "Experiencia Laboral",
        html: `<div class="book-entries">
            <div class="entry">
                <h4>Freelance Full Stack Developer</h4>
                <span class="date">2024 &mdash; 2025</span>
                <ul>
                    <li>Diseño y desarrollo de soluciones enfocadas en mejorar la experiencia del usuario final en tecnologías como SolidJS y Angular 18.</li>
                    <li>Enfoque en aplicaciones web TV (Tizen, LG), implementación y mejora de funcionalidad según petición.</li>
                </ul>
            </div>
        </div>`,
    },
    {
        title: "Experiencia Laboral II",
        html: `<div class="book-entries">
            <div class="entry">
                <h4>Packar | React Native Developer</h4>
                <span class="date">2022 &mdash; 2023</span>
                <ul>
                    <li>Desarrollo de aplicaciones con enfoque en funcionalidad en primer y segundo plano, diseño de pantallas y conexión con bases de datos.</li>
                    <li>Implementación de un sistema de tracking en tiempo real, incluyendo permisos de ubicación en segundo plano.</li>
                </ul>
            </div>
        </div>`,
    },
    {
        title: "Formación",
        html: `<div class="book-entries">
            <div class="entry">
                <h4>Desarrollo de Aplicaciones Multiplataforma</h4>
                <span class="date">2025 &mdash; Actualidad</span>
                <p>Retamar - Ciclos formativos FP. Nota media: 9.4</p>
            </div>
            <div class="entry">
                <h4>Máster Full-Stack Developer</h4>
                <span class="date">2023 &mdash; 2024</span>
                <p>ThePower</p>
                <ul>
                    <li>Desarrollo avanzado de Frontend: React, Next.js, Angular, TS.</li>
                    <li>Backend: Express, MongoDB, PostgreSQL, Mongoose, Supabase.</li>
                </ul>
            </div>
        </div>`,
    },
    {
        title: "Conocimientos",
        html: `<div class="book-entries">
            <div class="entry">
                <h4>Stack Tecnológico</h4>
                <p>HTML/CSS, JS/TS, React, React Native, MongoDB, PSQL, Node.js, Express, NextJS, Angular, Jest, Vitest, Python, Java, Spring Boot.</p>
            </div>
            <br />
            <div class="entry">
                <h4>Idiomas</h4>
                <ul>
                    <li>Inglés: B2</li>
                    <li>Francés: A2</li>
                    <li>Alemán: A2</li>
                </ul>
            </div>
        </div>`,
    },
    {
        title: "Voluntariado e Int.",
        html: `<div class="book-entries">
            <div class="entry">
                <h4>Coordinador Cáritas</h4>
                <span class="date">2023 &mdash; Actualidad</span>
                <p>San Saturnino &mdash; Alcorcón</p>
            </div>
            <div class="entry">
                <h4>Acompañamiento hospitalario</h4>
                <span class="date">2022 &mdash; Actualidad</span>
                <p>Las Praderas (Pozuelo) / Hospital Alcorcón</p>
            </div>
            <br />
            <div class="entry">
                <h4>Otros intereses</h4>
                <p>Interés cultural por el teatro, ópera e historia. Lector y escritor de poesía y cuentos.</p>
            </div>
        </div>`,
    },
];

const totalPages = pages.length;
---

<div class="chronicle-book-container">
    <div class="book-spine" id="book-spine">
        <!-- Desktop: left page -->
        <div class="book-page left-page stationary desktop-only" id="stat-left">
            <div></div>
        </div>
        <!-- Binding -->
        <div class="book-binding desktop-only"></div>
        <!-- Desktop: right page -->
        <div
            class="book-page right-page stationary desktop-only"
            id="stat-right"
        >
            <div></div>
        </div>

        <!-- The 3D flipping page overlay -->
        <div
            class="flipping-page flip-next"
            id="flip-page"
            style="display:none;"
        >
            <div class="page-front">
                <div class="book-page right-page" id="flip-front"></div>
            </div>
            <div class="page-back">
                <div class="book-page left-page" id="flip-back"></div>
            </div>
        </div>

        <!-- Mobile single page -->
        <div
            class="mobile-only book-page right-page"
            id="mobile-page"
            style="flex:none;width:100%;padding:0;"
        >
            <div id="mobile-inner" style="padding:3rem 2rem;height:100%;"></div>
        </div>

        <!-- Controls -->
        <div class="book-controls corner-prev">
            <button id="btn-prev" disabled aria-label="Página anterior"
                >Anterior</button
            >
        </div>
        <div class="book-controls corner-next">
            <button id="btn-next" aria-label="Página siguiente"
                >Siguiente</button
            >
        </div>
    </div>
</div>

<script
    define:vars={{
        pagesJSON: JSON.stringify(
            pages.map((p) => ({
                title: p.title,
                dropCap: p.dropCap || null,
                html: p.html,
            })),
        ),
        totalPages,
    }}
>
    window.__chroniclePages = JSON.parse(pagesJSON);
    window.__chronicleTotalPages = totalPages;
</script>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const pages: { title: string; dropCap: string | null; html: string }[] =
            (window as any).__chroniclePages;
        const totalPages: number = (window as any).__chronicleTotalPages;

        let pageIndex = 0;
        let isFlipping = false;
        let isMobile = window.innerWidth <= 800;

        // DOM refs
        const statLeftInner = document.querySelector(
            "#stat-left > div",
        ) as HTMLElement;
        const statRightInner = document.querySelector(
            "#stat-right > div",
        ) as HTMLElement;
        const flipPage = document.getElementById("flip-page")!;
        const flipFront = document.getElementById("flip-front")!;
        const flipBack = document.getElementById("flip-back")!;
        const mobileInner = document.getElementById("mobile-inner")!;
        const btnPrev = document.getElementById(
            "btn-prev",
        ) as HTMLButtonElement;
        const btnNext = document.getElementById(
            "btn-next",
        ) as HTMLButtonElement;

        function pageHTML(idx: number): string {
            if (idx < 0 || idx >= totalPages) return "";
            const p = pages[idx];
            return `
                <h3 class="page-title">${p.title}</h3>
                <div class="page-content">
                    ${p.dropCap ? `<p class="drop-cap">${p.dropCap}</p>` : ""}
                    ${p.html}
                </div>
                <div class="page-number">${idx + 1}</div>
            `;
        }

        function showStationary() {
            statLeftInner.innerHTML = pageHTML(pageIndex);
            statRightInner.innerHTML = pageHTML(pageIndex + 1);
        }

        function showMobile() {
            mobileInner.innerHTML = pageHTML(pageIndex);
        }

        function updateButtons() {
            btnPrev.disabled = pageIndex === 0 || isFlipping;
            btnNext.disabled =
                (isMobile
                    ? pageIndex >= totalPages - 1
                    : pageIndex >= totalPages - 2) || isFlipping;
        }

        function nextPage() {
            if (isFlipping) return;

            if (isMobile) {
                if (pageIndex >= totalPages - 1) return;
                isFlipping = true;
                updateButtons();
                gsap.to(mobileInner, {
                    opacity: 0,
                    x: -20,
                    duration: 0.2,
                    onComplete: () => {
                        pageIndex++;
                        showMobile();
                        gsap.fromTo(
                            mobileInner,
                            { opacity: 0, x: 20 },
                            {
                                opacity: 1,
                                x: 0,
                                duration: 0.3,
                                ease: "power2.out",
                                onComplete: () => {
                                    isFlipping = false;
                                    updateButtons();
                                },
                            },
                        );
                    },
                });
                return;
            }

            if (pageIndex >= totalPages - 2) return;
            isFlipping = true;
            updateButtons();

            // Prepare the flip overlay
            flipPage.className = "flipping-page flip-next desktop-only";
            flipPage.style.display = "";
            gsap.set(flipPage, { rotateY: 0, transformOrigin: "-20px 50%" });

            // Front of flipping page = current right page content
            flipFront.innerHTML = pageHTML(pageIndex + 1);
            // Back of flipping page = new left page content
            flipBack.innerHTML = pageHTML(pageIndex + 2);

            // Show destination right page behind the flip
            statRightInner.innerHTML = pageHTML(pageIndex + 3);

            gsap.to(flipPage, {
                rotateY: -180,
                duration: 1.2,
                ease: "power2.inOut",
                onComplete: () => {
                    pageIndex += 2;
                    flipPage.style.display = "none";
                    flipPage.style.transformOrigin = "calc(100% + 20px) 50%";
                    showStationary();
                    isFlipping = false;
                    updateButtons();
                },
            });
        }

        function prevPage() {
            if (isFlipping) return;

            if (isMobile) {
                if (pageIndex <= 0) return;
                isFlipping = true;
                updateButtons();
                gsap.to(mobileInner, {
                    opacity: 0,
                    x: 20,
                    duration: 0.2,
                    onComplete: () => {
                        pageIndex--;
                        showMobile();
                        gsap.fromTo(
                            mobileInner,
                            { opacity: 0, x: -20 },
                            {
                                opacity: 1,
                                x: 0,
                                duration: 0.3,
                                ease: "power2.out",
                                onComplete: () => {
                                    isFlipping = false;
                                    updateButtons();
                                },
                            },
                        );
                    },
                });
                return;
            }

            if (pageIndex <= 0) return;
            isFlipping = true;
            updateButtons();

            flipPage.className = "flipping-page flip-prev desktop-only";
            flipPage.style.display = "";
            gsap.set(flipPage, { rotateY: 0 });

            // Front = current left page
            flipFront.innerHTML = pageHTML(pageIndex);
            // Back = previous right page
            flipBack.innerHTML = pageHTML(pageIndex - 1);

            // Show destination left behind
            statLeftInner.innerHTML = pageHTML(pageIndex - 2);

            gsap.to(flipPage, {
                rotateY: 180,
                duration: 1.2,
                ease: "power2.inOut",
                onComplete: () => {
                    pageIndex -= 2;
                    flipPage.style.display = "none";
                    showStationary();
                    isFlipping = false;
                    updateButtons();
                },
            });
        }

        // Init
        showStationary();
        showMobile();
        updateButtons();

        btnNext.addEventListener("click", nextPage);
        btnPrev.addEventListener("click", prevPage);

        window.addEventListener("resize", () => {
            const wasMobile = isMobile;
            isMobile = window.innerWidth <= 800;
            if (wasMobile !== isMobile) {
                if (!isMobile && pageIndex % 2 !== 0) pageIndex--;
                showStationary();
                showMobile();
                updateButtons();
            }
        });
    });
</script>
