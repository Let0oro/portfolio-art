---
import "../styles/sections/_contact.scss";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="contact-section">
  <div class="contact-section__header">
    <span class="contact-section__num">04</span>
    <!-- <h2 class="contact-section__title">
      Corres<span class="accent">pon</span><br />dence
    </h2> -->
    <h2 class="contact-section__title">
      The<br />Lett<span class="accent">ers</span>
    </h2>
    <p class="contact-section__subtitle">{t("contact.subtitle")}</p>
  </div>

  <div class="contact-section__container">
    <form class="contact-section__form" onsubmit="event.preventDefault()">
      <div class="form-group">
        <label for="name">{t("contact.formName")}</label>
        <input type="text" id="name" required />
      </div>
      <div class="form-group">
        <label for="email">{t("contact.formEmail")}</label>
        <input type="email" id="email" required />
      </div>
      <div class="form-group">
        <label for="message">{t("contact.formMessage")}</label>
        <textarea id="message" required></textarea>
      </div>
      <button type="submit">{t("contact.formSubmit")}</button>
    </form>

    <div class="contact-section__links">
      <a href="mailto:example@domain.com">Email →</a>
      <a href="https://github.com" target="_blank">GitHub →</a>
      <a href="https://linkedin.com" target="_blank">LinkedIn →</a>
    </div>
  </div>
</section>
