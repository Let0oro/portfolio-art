    //   .fromTo(
    //     ".hero-poster__statue img",
    //     { opacity: 0, scale: 0.9 },
    //     { opacity: 1, scale: 1, duration: 1.2 },
    //     "-=0.8",
    //   )
    //   .fromTo(
    //     ".hero-poster__info-left",
    //     { opacity: 0, y: 30 },
    //     { opacity: 1, y: 0, duration: 0.8 },
