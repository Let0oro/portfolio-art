---
import "../styles/sections/_hero.scss";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base =
  process.env.NODE_ENV === "production" ? import.meta.env.BASE_URL : "";
---

<section id="hero" class="hero-poster">
  <!-- Ink Reveal GIF Mask -->
  <img
    id="ink-reveal-gif"
    src={`${base}/videos/ink-reveal.gif`}
    alt=""
    class="hero-poster__ink-mask"
    aria-hidden="true"
  />

  <!-- Canvas grain overlay -->
  <div class="hero-poster__grain" aria-hidden="true"></div>

  <!-- Small top tagline like the poster -->
  <p class="hero-poster__tagline">{t("hero.tagline")}</p>

  <!-- MASSIVE name — split into lines with mixed color -->
  <div class="hero-poster__title-block">
    <h1 class="hero-poster__name">
      <span class="line-1">JU<span class="accent">AN</span>MA</span>
      <span class="line-2">MON<span class="accent">TE</span>RO</span>
    </h1>
  </div>

  <!-- The statue image — overlapping the typography -->
  <div class="hero-poster__statue">
    <img
      src={`${base}/images/statue-hero.png`}
      alt="Classical statue illustration"
    />
  </div>

  <div class="hero-poster__info-left">
    <p class="hero-poster__role">
      <strong>{t("hero.dev")}</strong><br />
      <span set:html={t("hero.designer")} />
    </p>
  </div>

  <!-- Bottom right block -->
  <div class="hero-poster__info-right">
    <span class="hero-poster__label">{t("hero.label1")}</span>
    <span class="hero-poster__label">{t("hero.label2")}</span>
    <span class="hero-poster__diamond">✦</span>
  </div>

  <!-- Bottom large text -->
  <div class="hero-poster__bottom-title">
    <div class="hero-poster__bottom-word">{t("hero.bottom1")}</div>
    <span class="hero-poster__bottom-sub">{t("hero.bottom2")}</span>
  </div>

  <div class="page-corner-ornament" aria-hidden="true"></div>
</section>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    const inkGif = document.getElementById(
      "ink-reveal-gif",
    ) as HTMLImageElement;

    // Fade out and remove the GIF rapidly before it loops
    if (inkGif) {
      gsap.to(inkGif, {
        opacity: 0,
        duration: 1.5,
        delay: 1.5,
        onComplete: () => {
          inkGif.style.display = "none";
        },
      });
    }

    // Start hero element animations immediately

    // tl.fromTo(
