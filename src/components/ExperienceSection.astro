---
import ChronicleBook from "./ChronicleBook.astro";
import "../styles/sections/_experience.scss";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="experience" class="experience-section">
  <div class="experience-section__header">
    <span class="experience-section__num">03</span>
    <h2 class="experience-section__title">
      The<br />Chron<span class="accent">icle</span>
    </h2>
    <p class="experience-section__subtitle">{t("chronicle.subtitle")}</p>
  </div>
  <ChronicleBook />
</section>
